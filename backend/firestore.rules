rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSeedAdminEmail() {
      return isSignedIn() && request.auth.token.email == "rkamle369@gmail.com";
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    match /admins/{uid} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == uid);
      allow create: if isSeedAdminEmail() && request.auth.uid == uid;
      allow update, delete: if isAdmin();
    }

    // Public read for course catalog (logged-in users only)
    match /courses/{courseId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();

      // Optional chapters subcollection under courses
      match /chapters/{chapterId} {
        allow read: if isSignedIn();
        allow write: if isAdmin();
      }
    }

    // User profile/preferences
    match /users/{uid} {
      allow read, create, update: if isOwner(uid);
      allow delete: if false;

      // Per-course progress
      match /courseProgress/{courseId} {
        allow read, create, update: if isOwner(uid);
        allow delete: if false;
      }
    }
  }
}
