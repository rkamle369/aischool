LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_LLM_TEMPERATURE=0.35
OPENAI_STT_MODEL=gpt-4o-mini-transcribe
# Optional OpenAI STT noise shaping: far_field | near_field (leave empty to skip)
OPENAI_STT_NOISE_REDUCTION=far_field

OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy

# TTS: openai (default) or elevenlabs (lower latency / different voice quality)
AGENT_TTS_PROVIDER=openai
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5

# Hindi companion overrides (optional)
# Set to sarvam to indicate intent, but current runtime falls back to elevenlabs/openai
# until a full Sarvam streaming TTS adapter is added.
HINDI_AGENT_TTS_PROVIDER=elevenlabs
SARVAM_API_KEY=
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_TTS_SPEAKER=suhani

# Silero VAD: higher activation + longer silence reduces false triggers from background noise
VAD_ACTIVATION_THRESHOLD=0.65
VAD_MIN_SILENCE_DURATION=0.85
VAD_MIN_SPEECH_DURATION=0.12

# LiveKit inbound noise cancellation (requires livekit-plugins-noise-cancellation)
ENABLE_AGENT_NOISE_CANCELLATION=true

AGENT_NAME=ai-tutor
LIVEKIT_INSECURE_SKIP_VERIFY=false
